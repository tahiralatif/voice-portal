# Voice Portal Environment Variables
# Copy to .env and fill in your keys

# Groq API Key (for LLM)
GROQ_API_KEY=your_groq_api_key_here

# HF Token (optional, for Engine B cloud STT)
HF_TOKEN=

# Backend port
BACKEND_PORT=8005

# Frontend port
FRONTEND_PORT=3005

# Database path
DB_PATH=/root/voice-portal/voice_portal.db

# Piper model path
PIPER_MODEL_PATH=/root/voice-portal/models/piper

# Whisper model path
WHISPER_MODEL_PATH=/root/voice-portal/models/whisper
